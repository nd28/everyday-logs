#!/usr/bin/env bash

set -euo pipefail

dir=${EVERYDAY_LOGS_DIR:-$HOME/everyday-logs}
log_date=$(date +%Y-%m-%d)
file=$dir/$log_date.md
todo_file=$dir/todo.txt
done_file=$dir/done.txt

init() {
	mkdir -p "$dir"
	if [[ ! -f $todo_file ]]; then
		echo "# Todo.txt - edit manually or use 'log add'" > "$todo_file"
	fi
	if [[ ! -f $done_file ]]; then
		echo "# Done.txt - completed tasks" > "$done_file"
	fi
}

new() {
	init
	if [[ -f $file ]]; then
		echo "Today's log already exists: $file"
		exit 1
	fi
	cat > "$file" << 'EOF'
# Log - DATE

## Tasks
-

## Notes
-

## Research
-

## Reminders
-

EOF
	sed -i "s/DATE/$log_date/" "$file"
	echo "Created: $file"
	${EDITOR:-nvim} "$file"
}

today() {
	init
	if [[ ! -f $file ]]; then
		echo "No log for today. Run 'log new' first."
		exit 1
	fi
	${EDITOR:-nvim} "$file"
}

tasks() {
	init
	echo "=== TODO ==="
	grep -vE '^#|^$' "$todo_file" | cat -n || true
	echo ""
	echo "=== DONE (last 5) ==="
	tail -5 "$done_file" 2>/dev/null | grep -vE '^#|^$' || true
}

add() {
	init
	if [[ -z ${1:-} ]]; then
		echo "Usage: log add <task>"
		exit 1
	fi
	echo "$1" >> "$todo_file"
	echo "Added: $1"
}

complete() {
	init
	if [[ -z ${1:-} ]]; then
		if command -v fzf &>/dev/null; then
			task=$(grep -vE '^#|^$' "$todo_file" | fzf --prompt="Select task to complete> " --height=~50% --reverse)
			if [[ -z $task ]]; then
				echo "No task selected"
				exit 1
			fi
			grep -v -F -- "$task" "$todo_file" > "$todo_file.tmp" && mv "$todo_file.tmp" "$todo_file"
			echo "x $log_date $task" >> "$done_file"
			echo "Marked done: $task"
			exit 0
		else
			echo "Usage: log complete <task number>"
			echo "Or install fzf for interactive: brew install fzf"
			exit 1
		fi
	fi
	task=$(sed -n "${1}p" "$todo_file")
	if [[ -z $task ]] || [[ $task == \#* ]]; then
		echo "No task at line $1"
		exit 1
	fi
	sed -i "${1}d" "$todo_file"
	echo "x $log_date $task" >> "$done_file"
	echo "Marked done: $task"
}

search() {
	if command -v fzf &>/dev/null && [[ -z ${1:-} ]]; then
		results=""
		for f in "$dir"/[0-9]*.md; do
			[[ -f $f ]] || continue
			while IFS= read -r line; do
				[[ -n $line ]] && results+="${f##*/}: $line"$'\n'
			done < <(grep -in '.' "$f")
		done
		if [[ -z $results ]]; then
			echo "No logs found"
			exit 1
		fi
		echo "$results" | fzf --prompt="Search logs> " --height=~80% --nth=2..
		exit 0
	fi
	if [[ -z ${1:-} ]]; then
		echo "Usage: log search <term>"
		echo "       log search       (interactive with fzf)"
		exit 1
	fi
	term=$1
	echo "=== Searching for: $term ==="
	for f in "$dir"/[0-9]*.md; do
		[[ -f $f ]] || continue
		match=$(grep -i "$term" "$f")
		if [[ -n $match ]]; then
			echo ""
			echo "--- ${f##*/} ---"
			echo "$match"
		fi
	done
}

week() {
	echo "=== Last 7 Days ==="
	for i in {0..6}; do
		date=$(date -d "-$i days" +%Y-%m-%d)
		log=$dir/$date.md
		if [[ -f $log ]]; then
			echo ""
			echo "--- $date ---"
			grep -E '^## Tasks|^## Notes|^## Research' "$log" || true
		fi
	done
}

backup() {
	if ! command -v git &>/dev/null; then
		echo "git not found"
		exit 1
	fi
	cd "$dir" || exit
	if [[ ! -d .git ]]; then
		git init
		git add .
		git commit -m "Initial commit"
		echo "Initialized git repo"
	fi
	git add .
	git commit -m "Backup: $log_date" || echo "No changes to commit"
	echo "Backup complete"
}

restore() {
	if [[ -z ${1:-} ]]; then
		echo "Usage: log restore <commit>"
		exit 1
	fi
	cd "$dir" || exit
	git checkout "$1" -- .
}

doctor() {
	echo "=== everyday-logs Doctor ==="
	echo ""

	echo "1. Checking directory..."
	if [[ -d $dir ]]; then
		echo "   ✓ Directory exists: $dir"
	else
		echo "   ✗ Directory missing: $dir"
		echo "   → Run 'log init' to create"
	fi
	echo ""

	echo "2. Checking files..."
	for f in todo.txt done.txt README.md; do
		if [[ -f $dir/$f ]]; then
			echo "   ✓ $f exists"
		else
			echo "   ✗ $f missing"
		fi
	done
	echo ""

	echo "3. Checking git..."
	if [[ -d $dir/.git ]]; then
		echo "   ✓ Git repo initialized"
	else
		echo "   ✗ Git not initialized"
		echo "   → Run 'log backup' to init"
	fi
	echo ""

	echo "4. Checking PATH..."
	if [[ :$PATH: == *"$dir"* ]]; then
		echo "   ✓ Directory in PATH"
	else
		echo "   ✗ Not in PATH"
		echo "   → Add to shell rc: export PATH=\"\$PATH:$dir\""
	fi
	echo ""

	echo "5. Checking EDITOR..."
	if [[ -n ${EDITOR:-} ]]; then
		echo "   ✓ EDITOR set to: $EDITOR"
	else
		echo "   ✗ EDITOR not set (defaulting to nvim)"
	fi
	echo ""

	echo "6. Checking fzf..."
	if command -v fzf &>/dev/null; then
		echo "   ✓ fzf installed (interactive features available)"
	else
		echo "   ✗ fzf not found"
		echo "   → Install: brew install fzf (or apt install fzf)"
	fi
	echo ""

	echo "=== Quick Tour ==="
	echo ""
	echo "Daily workflow:"
	echo "  log new              → Create today's log"
	echo "  log add \"Task\"      → Add a task"
	echo "  log tasks            → View all tasks"
	echo "  log edit             → Edit task (fzf)"
	echo "  log delete           → Delete task (fzf)"
	echo "  log complete         → Mark done (fzf or number)"
	echo "  log backup           → Commit to git"
	echo ""
	echo "Review:"
	echo "  log today            → Open today's log"
	echo "  log search           → Search logs (fzf or term)"
	echo "  log week             → Last 7 days summary"
}

edit() {
	init
	if command -v fzf &>/dev/null; then
		task=$(grep -vE '^#|^$' "$todo_file" | fzf --prompt="Select task to edit> " --height=~50% --reverse)
		if [[ -z $task ]]; then
			echo "No task selected"
			exit 1
		fi
		read -p "Edit task: " -i "$task" new_task
		while IFS= read -r line; do
			if [[ "$line" == "$task" ]]; then
				echo "$new_task"
			else
				echo "$line"
			fi
		done < "$todo_file" > "$todo_file.tmp" && mv "$todo_file.tmp" "$todo_file"
		echo "Updated: $task → $new_task"
	else
		echo "fzf not found. Install: brew install fzf (or apt install fzf)"
		exit 1
	fi
}

delete() {
	init
	if command -v fzf &>/dev/null; then
		task=$(grep -vE '^#|^$' "$todo_file" | fzf --prompt="Select task to delete> " --height=~50% --reverse)
		if [[ -z $task ]]; then
			echo "No task selected"
			exit 1
		fi
		grep -v -F -- "$task" "$todo_file" > "$todo_file.tmp" && mv "$todo_file.tmp" "$todo_file"
		echo "Deleted: $task"
	else
		echo "fzf not found. Install: brew install fzf (or apt install fzf)"
		exit 1
	fi
}

help() {
	cat << 'EOF'
Usage: log <command>

Commands:
  init      Initialize everyday-logs (scaffold files)
  new       Create today's log entry
  today     Open today's log
  tasks     Show todo and recent done tasks
  add       Add a task (Usage: log add "Buy milk")
  edit      Edit a task interactively (requires fzf)
  delete   Delete a task interactively (requires fzf)
  complete  Mark task as done (Usage: log complete 1, or use fzf)
  search    Search all logs (Usage: log search <term>, or interactive with fzf)
  week      Show last 7 days summary
  backup    Commit changes to git
  restore   Restore from git (Usage: log restore <commit>)
  doctor    Diagnose and show quick tour
  help      Show this help

Environment:
  EVERYDAY_LOGS_DIR  Set custom directory (default: ~/everyday-logs)
EOF
}

case ${1:-help} in
	init) init && echo "Initialized at $dir" ;;
	new) new ;;
	today) today ;;
	tasks) tasks ;;
	add) add "${2:-}" ;;
	edit) edit ;;
	delete) delete ;;
	complete) complete "${2:-}" ;;
	search) search "${2:-}" ;;
	week) week ;;
	backup) backup ;;
	restore) restore "${2:-}" ;;
	doctor) doctor ;;
	help) help ;;
	*) help ;;
esac
